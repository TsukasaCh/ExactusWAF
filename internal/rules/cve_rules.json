  "rules": [
    {
      "id": "GEN-SQLI-001",
      "name": "SQL Injection - UNION/SELECT",
      "cve": "",
      "severity": "high",
      "category": "sqli",
      "target": "all",
      "pattern": "(?i)(union[\\s/*]+select|select[\\s/*]+.*[\\s/*]+from|insert[\\s/*]+into|;[\\s]*drop[\\s]+table|' or '1'='1|\" or \"1\"=\"1|or 1=1--|sleep\\(\\d+\\)|benchmark\\(|pg_sleep\\()"
    },
    {
      "id": "GEN-SQLI-002",
      "name": "SQL Injection - Boolean/Time based",
      "cve": "",
      "severity": "high",
      "category": "sqli",
      "target": "all",
      "pattern": "(?i)(waitfor[\\s]+delay|extractvalue\\(|updatexml\\(|load_file\\(|into[\\s]+outfile|information_schema)"
    },
    {
      "id": "GEN-XSS-001",
      "name": "Cross-Site Scripting (XSS)",
      "cve": "",
      "severity": "high",
      "category": "xss",
      "target": "all",
      "pattern": "(?i)(<script[\\s>]|javascript:|onerror[\\s]*=|onload[\\s]*=|onmouseover[\\s]*=|<img[^>]+src[\\s]*=[\\s]*['\"]?[\\s]*javascript|document\\.cookie|<iframe|<svg[^>]+onload|eval\\(|alert\\()"
    },
    {
      "id": "GEN-LFI-001",
      "name": "Local File Inclusion / Path Traversal",
      "cve": "",
      "severity": "high",
      "category": "traversal",
      "target": "all",
      "pattern": "(?i)(\\.\\./\\.\\./|\\.\\.\\\\\\.\\.\\\\|/etc/passwd|/etc/shadow|c:\\\\windows\\\\|boot\\.ini|%2e%2e%2f|%2e%2e/|\\.\\.%2f|php://filter|php://input|file:///|/proc/self/environ)"
    },
    {
      "id": "GEN-RCE-001",
      "name": "Command Injection",
      "cve": "",
      "severity": "critical",
      "category": "rce",
      "target": "all",
      "pattern": "(?i)(;[\\s]*(cat|ls|id|whoami|uname|wget|curl|nc|bash|sh)[\\s;|]|\\|[\\s]*(cat|ls|id|whoami|uname)[\\s]|`[^`]+`|\\$\\([^)]+\\)|&&[\\s]*(cat|ls|id|whoami))"
    },
